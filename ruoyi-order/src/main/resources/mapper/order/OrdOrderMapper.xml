<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.order.mapper.OrdOrderMapper">
    
    <resultMap type="OrdOrder" id="OrdOrderResult">
        <result property="id"    column="id"    />
        <result property="orderSn"    column="order_sn"    />
        <result property="memberId"    column="member_id"    />
        <result property="status"    column="status"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="payAmount"    column="pay_amount"    />
        <result property="promotionAmount"    column="promotion_amount"    />
        <result property="freightAmount"    column="freight_amount"    />
        <result property="paymentType"    column="payment_type"    />
        <result property="paymentTime"    column="payment_time"    />
        <result property="expireTime"    column="expire_time"    />
        <result property="version"    column="version"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectOrdOrderVo">
        select id, order_sn, member_id, status, total_amount, pay_amount, promotion_amount, freight_amount, payment_type, payment_time, expire_time, version, create_time, update_time from ord_order
    </sql>

    <select id="selectOrdOrderList" parameterType="OrdOrder" resultMap="OrdOrderResult">
        <include refid="selectOrdOrderVo"/>
        <where>  
            <if test="orderSn != null  and orderSn != ''"> and order_sn = #{orderSn}</if>
            <if test="memberId != null "> and member_id = #{memberId}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="totalAmount != null "> and total_amount = #{totalAmount}</if>
            <if test="payAmount != null "> and pay_amount = #{payAmount}</if>
            <if test="promotionAmount != null "> and promotion_amount = #{promotionAmount}</if>
            <if test="freightAmount != null "> and freight_amount = #{freightAmount}</if>
            <if test="paymentType != null "> and payment_type = #{paymentType}</if>
            <if test="paymentTime != null "> and payment_time = #{paymentTime}</if>
            <if test="expireTime != null "> and expire_time = #{expireTime}</if>
            <if test="version != null "> and version = #{version}</if>
        </where>
    </select>
    
    <select id="selectOrdOrderById" parameterType="Long" resultMap="OrdOrderResult">
        <include refid="selectOrdOrderVo"/>
        where id = #{id}
    </select>

    <insert id="insertOrdOrder" parameterType="OrdOrder" useGeneratedKeys="true" keyProperty="id">
        insert into ord_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderSn != null and orderSn != ''">order_sn,</if>
            <if test="memberId != null">member_id,</if>
            <if test="status != null">status,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="payAmount != null">pay_amount,</if>
            <if test="promotionAmount != null">promotion_amount,</if>
            <if test="freightAmount != null">freight_amount,</if>
            <if test="paymentType != null">payment_type,</if>
            <if test="paymentTime != null">payment_time,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="version != null">version,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderSn != null and orderSn != ''">#{orderSn},</if>
            <if test="memberId != null">#{memberId},</if>
            <if test="status != null">#{status},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="payAmount != null">#{payAmount},</if>
            <if test="promotionAmount != null">#{promotionAmount},</if>
            <if test="freightAmount != null">#{freightAmount},</if>
            <if test="paymentType != null">#{paymentType},</if>
            <if test="paymentTime != null">#{paymentTime},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="version != null">#{version},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateOrdOrder" parameterType="OrdOrder">
        update ord_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderSn != null and orderSn != ''">order_sn = #{orderSn},</if>
            <if test="memberId != null">member_id = #{memberId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="payAmount != null">pay_amount = #{payAmount},</if>
            <if test="promotionAmount != null">promotion_amount = #{promotionAmount},</if>
            <if test="freightAmount != null">freight_amount = #{freightAmount},</if>
            <if test="paymentType != null">payment_type = #{paymentType},</if>
            <if test="paymentTime != null">payment_time = #{paymentTime},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="version != null">version = #{version},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteOrdOrderById" parameterType="Long">
        delete from ord_order where id = #{id}
    </delete>

    <delete id="deleteOrdOrderByIds" parameterType="String">
        delete from ord_order where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>