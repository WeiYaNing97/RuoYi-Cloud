<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.order.mapper.OrdPaymentMapper">
    
    <resultMap type="OrdPayment" id="OrdPaymentResult">
        <result property="id"    column="id"    />
        <result property="orderId"    column="order_id"    />
        <result property="paymentSn"    column="payment_sn"    />
        <result property="transactionId"    column="transaction_id"    />
        <result property="amount"    column="amount"    />
        <result property="status"    column="status"    />
        <result property="paymentTime"    column="payment_time"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectOrdPaymentVo">
        select id, order_id, payment_sn, transaction_id, amount, status, payment_time, create_time from ord_payment
    </sql>

    <select id="selectOrdPaymentList" parameterType="OrdPayment" resultMap="OrdPaymentResult">
        <include refid="selectOrdPaymentVo"/>
        <where>  
            <if test="orderId != null "> and order_id = #{orderId}</if>
            <if test="paymentSn != null  and paymentSn != ''"> and payment_sn = #{paymentSn}</if>
            <if test="transactionId != null  and transactionId != ''"> and transaction_id = #{transactionId}</if>
            <if test="amount != null "> and amount = #{amount}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="paymentTime != null "> and payment_time = #{paymentTime}</if>
        </where>
    </select>
    
    <select id="selectOrdPaymentById" parameterType="Long" resultMap="OrdPaymentResult">
        <include refid="selectOrdPaymentVo"/>
        where id = #{id}
    </select>

    <insert id="insertOrdPayment" parameterType="OrdPayment" useGeneratedKeys="true" keyProperty="id">
        insert into ord_payment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderId != null">order_id,</if>
            <if test="paymentSn != null and paymentSn != ''">payment_sn,</if>
            <if test="transactionId != null">transaction_id,</if>
            <if test="amount != null">amount,</if>
            <if test="status != null">status,</if>
            <if test="paymentTime != null">payment_time,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderId != null">#{orderId},</if>
            <if test="paymentSn != null and paymentSn != ''">#{paymentSn},</if>
            <if test="transactionId != null">#{transactionId},</if>
            <if test="amount != null">#{amount},</if>
            <if test="status != null">#{status},</if>
            <if test="paymentTime != null">#{paymentTime},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateOrdPayment" parameterType="OrdPayment">
        update ord_payment
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="paymentSn != null and paymentSn != ''">payment_sn = #{paymentSn},</if>
            <if test="transactionId != null">transaction_id = #{transactionId},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="paymentTime != null">payment_time = #{paymentTime},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteOrdPaymentById" parameterType="Long">
        delete from ord_payment where id = #{id}
    </delete>

    <delete id="deleteOrdPaymentByIds" parameterType="String">
        delete from ord_payment where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>